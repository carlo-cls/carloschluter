---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- NAVIGATION -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-4 border-b border-white/5" style="background:#0d0f14;">
    <div class="text-white font-bold text-lg tracking-tight">
      carlo<span style="color:#00d4aa">.</span>schluter
    </div>
    <div class="hidden md:flex items-center gap-8">
      <a href="#about" class="text-sm text-[#8b909e] hover:text-white transition-colors">About</a>
      <a href="#services" class="text-sm text-[#8b909e] hover:text-white transition-colors">Services</a>
      <a href="#process" class="text-sm text-[#8b909e] hover:text-white transition-colors">Process</a>
      <a href="#skills" class="text-sm text-[#8b909e] hover:text-white transition-colors">Skills</a>
      <a href="#contact" class="text-sm text-[#8b909e] hover:text-white transition-colors">Contact</a>
    </div>
    <a href="#contact" class="text-sm font-semibold px-4 py-2 rounded-lg transition-colors" style="background:#00d4aa;color:#0d0f14;">
      Let's talk
    </a>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-8 pt-24 pb-16 max-w-6xl mx-auto">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium mb-8 w-fit" style="background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.25);color:#00d4aa;">
      <span class="w-2 h-2 rounded-full" style="background:#00d4aa;"></span>
      Available for AI projects · Gauteng, South Africa
    </div>

    <h1 class="text-5xl md:text-7xl font-bold leading-tight tracking-tight mb-6">
      Carlo Schluter<br />
      <span style="background:linear-gradient(135deg,#00d4aa,#5b8dee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
        AI Solutions Engineer
      </span>
    </h1>

    <p class="text-lg text-[#8b909e] max-w-xl leading-relaxed mb-10">
      I help <strong class="text-[#c8cad4] font-medium">South African businesses</strong> implement AI in ways that are practical, meaningful, and built to last — without the jargon, without the overwhelm.
    </p>

    <div class="flex flex-wrap gap-4 mb-16">
      <a href="#services" class="px-6 py-3 rounded-lg font-semibold text-sm transition-opacity hover:opacity-90" style="background:#00d4aa;color:#0d0f14;">
        See what I build
      </a>
      <a href="#contact" class="px-6 py-3 rounded-lg font-semibold text-sm border transition-colors hover:border-white/30" style="border-color:rgba(255,255,255,0.12);color:#e8eaf0;">
        Get in touch
      </a>
    </div>

    <div class="flex flex-wrap gap-12 pt-8 border-t border-white/5">
      <div>
        <div class="text-3xl font-bold text-white">25+</div>
        <div class="text-sm text-[#8b909e] mt-1">Years engineering</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-white">3</div>
        <div class="text-sm text-[#8b909e] mt-1">AI specialisations</div>
      </div>
      <div>
        <div class="text-3xl font-bold" style="color:#00d4aa;">SA</div>
        <div class="text-sm text-[#8b909e] mt-1">Based in Gauteng</div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-24 px-8 max-w-6xl mx-auto border-t border-white/5">
    <div class="flex flex-col md:flex-row items-center gap-16">

      <!-- Photo -->
      <div id="photo-outer" class="relative flex-shrink-0 flex items-center justify-center" style="width:220px;height:254px;">

        <!-- Outer rotating ring -->
        <div style="
          position:absolute;
          inset:-4px;
          border-radius:4px;
          background:conic-gradient(from 0deg,#00d4aa,#5b8dee,#00d4aa);
          clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
          animation:rotatering 6s linear infinite;
          opacity:0.85;
        "></div>

        <!-- Dark inset behind photo -->
        <div style="
          position:absolute;
          inset:3px;
          background:#0d0f14;
          clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
        "></div>

        <!-- Photo with teal tint effect -->
        <div class="photo-hex-wrap" style="
          position:absolute;
          inset:5px;
          clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
          overflow:hidden;
        ">
        <img
          id="carlo-photo"
          src="/images/carlo.jpg"
          alt="Carlo Schluter"
          style="
            width:100%;
            height:100%;
            object-fit:cover;
            object-position:top;
            filter:saturate(0.15) brightness(0.9) sepia(0.4) hue-rotate(130deg) contrast(1.1);
            transition:filter 0.5s ease;
          "
        />
        <div
          id="teal-overlay"
          style="
            position:absolute;
            inset:0;
            background:rgba(0,212,170,0.12);
            mix-blend-mode:screen;
            transition:opacity 0.5s ease;
          "
        ></div> 
        </div>

        <!-- Dashed outer hex ring -->
        <svg style="position:absolute;inset:-12px;width:calc(100% + 24px);height:calc(100% + 24px);overflow:visible;" viewBox="0 0 244 278">
          <polygon
            points="122,6 238,68 238,210 122,272 6,210 6,68"
            fill="none"
            stroke="#5b8dee"
            stroke-width="1"
            stroke-dasharray="6 5"
            opacity="0.4"
          />
        </svg>

        <!-- Available badge -->
        <div style="
          position:absolute;
          bottom:-18px;
          left:50%;
          transform:translateX(-50%);
          display:flex;
          align-items:center;
          gap:6px;
          padding:5px 14px;
          border-radius:20px;
          font-size:11px;
          font-weight:600;
          white-space:nowrap;
          background:#0d0f14;
          border:1px solid rgba(0,212,170,0.4);
          color:#00d4aa;
        ">
          <span style="width:6px;height:6px;border-radius:50%;background:#00d4aa;animation:pulse 2s infinite;"></span>
          Available for projects
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1">
        <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">About me</div>
        <h2 class="text-3xl font-bold text-white mb-6">Bridging AI capability<br/>and business reality</h2>
        <p class="text-[#8b909e] leading-relaxed mb-4">
          I'm a Development Team Lead and AI Solutions Engineer based in Gauteng, South Africa, with over 25 years of experience building production software systems — from enterprise web platforms and real-time data pipelines to CRM integrations and mobile applications.
        </p>
        <p class="text-[#8b909e] leading-relaxed mb-4">
          What drives me is the translation work — taking something technically complex and turning it into something that genuinely works for a business and its people. I remove unnecessary complexity, communicate clearly without jargon, and build solutions that hold up long after I've handed them over.
        </p>
        <p class="text-[#8b909e] leading-relaxed mb-8">
          Now I'm applying that same approach to AI — helping established South African businesses implement intelligent systems that save time, surface insights, and create real competitive advantage.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://linkedin.com/in/carloschluter" target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-colors hover:border-[#00d4aa]/50" style="border-color:rgba(255,255,255,0.12);color:#e8eaf0;">
            <i class="ti ti-brand-linkedin" style="color:#0077b5;"></i>
            LinkedIn
          </a>
          <a href="https://github.com/carlo-cls" target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-colors hover:border-[#00d4aa]/50" style="border-color:rgba(255,255,255,0.12);color:#e8eaf0;">
            <i class="ti ti-brand-github"></i>
            GitHub
          </a>
        </div>
      </div>

    </div>
  </section>

  <style>
    @keyframes rotatering {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    .photo-hex-wrap:hover .photo-hex {
      filter: saturate(1) brightness(1) sepia(0) hue-rotate(0deg) contrast(1) !important;
    }
    .photo-hex-wrap:hover .teal-overlay {
      opacity: 0 !important;
    }
    html {
      scroll-behavior: smooth;
    }
  </style>  

  <!-- SERVICES -->
  <section id="services" class="py-24 px-8 max-w-6xl mx-auto">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">What I build</div>
    <h2 class="text-3xl font-bold text-white mb-12">AI solutions for real business problems</h2>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl border transition-colors hover:border-[#00d4aa]/30" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <i class="ti ti-brain text-2xl mb-4 block" style="color:#00d4aa;"></i>
        <h3 class="font-semibold text-white mb-3">AI Web Solutions</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">Intelligent apps, chatbots, smart search, and automation built directly into your web presence.</p>
      </div>
      <div class="p-6 rounded-xl border transition-colors hover:border-[#5b8dee]/30" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <i class="ti ti-speakerphone text-2xl mb-4 block" style="color:#5b8dee;"></i>
        <h3 class="font-semibold text-white mb-3">AI Marketing Systems</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">Content automation, social media AI, ad copy generation, and campaign intelligence at scale.</p>
      </div>
      <div class="p-6 rounded-xl border transition-colors hover:border-[#EF9F27]/30" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <i class="ti ti-rocket text-2xl mb-4 block" style="color:#EF9F27;"></i>
        <h3 class="font-semibold text-white mb-3">SaaS AI Integration</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">Embed AI features into your product — prompt pipelines, RAG systems, and agentic workflows.</p>
      </div>
    </div>
  </section>

  <!-- HOW I WORK -->
  <section id="process" class="py-24 px-8 max-w-6xl mx-auto border-t border-white/5">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">My process</div>
    <h2 class="text-3xl font-bold text-white mb-4">How I work</h2>
    <p class="text-[#8b909e] mb-16 max-w-xl">Every engagement follows the same four steps — no surprises, no black boxes. You know exactly what's happening and why at every stage.</p>

    <div class="grid md:grid-cols-4 gap-6">

      <div class="relative p-6 rounded-xl border" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <div class="text-5xl font-bold mb-4" style="color:rgba(0,212,170,0.15);">01</div>
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(0,212,170,0.1);">
          <i class="ti ti-search" style="color:#00d4aa;font-size:18px;"></i>
        </div>
        <h3 class="font-semibold text-white mb-2">Discovery</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">I learn how your business operates, where the friction is, and where AI can genuinely create value.</p>
      </div>

      <div class="relative p-6 rounded-xl border" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <div class="text-5xl font-bold mb-4" style="color:rgba(91,141,238,0.15);">02</div>
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(91,141,238,0.1);">
          <i class="ti ti-map" style="color:#5b8dee;font-size:18px;"></i>
        </div>
        <h3 class="font-semibold text-white mb-2">Strategy</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">We define the solution together — what to build, what tools to use, what success looks like, and what it will cost.</p>
      </div>

      <div class="relative p-6 rounded-xl border" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <div class="text-5xl font-bold mb-4" style="color:rgba(239,159,39,0.15);">03</div>
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(239,159,39,0.1);">
          <i class="ti ti-code" style="color:#EF9F27;font-size:18px;"></i>
        </div>
        <h3 class="font-semibold text-white mb-2">Build</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">I design, build, and test the solution — keeping you informed throughout with clear updates in plain language.</p>
      </div>

      <div class="relative p-6 rounded-xl border" style="background:#131720;border-color:rgba(255,255,255,0.07);">
        <div class="text-5xl font-bold mb-4" style="color:rgba(0,212,170,0.15);">04</div>
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background:rgba(0,212,170,0.1);">
          <i class="ti ti-rocket" style="color:#00d4aa;font-size:18px;"></i>
        </div>
        <h3 class="font-semibold text-white mb-2">Handover</h3>
        <p class="text-sm text-[#8b909e] leading-relaxed">You get full ownership — documentation, training, and ongoing support so your team can use and maintain what we built.</p>
      </div>

    </div>

    <!-- Connector line (desktop only) -->
    <div class="hidden md:flex items-center justify-between mt-6 px-6">
      <div class="h-px flex-1" style="background:linear-gradient(to right,#00d4aa,#5b8dee,#EF9F27,#00d4aa);opacity:0.3;"></div>
    </div>

  </section>  

  <!-- SKILLS -->
  <section id="skills" class="py-24 px-8 max-w-6xl mx-auto border-t border-white/5">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">Tech stack</div>
    <h2 class="text-3xl font-bold text-white mb-12">Tools & technologies</h2>

    <div class="flex flex-wrap gap-3">
      {[
        {label:'Prompt Engineering',hot:true},
        {label:'Claude API',hot:true},
        {label:'LangChain',hot:true},
        {label:'RAG Systems',hot:true},
        {label:'Spring Boot',hot:false},
        {label:'Java',hot:false},
        {label:'MySQL',hot:false},
        {label:'JavaScript',hot:false},
        {label:'Bootstrap',hot:false},
        {label:'jQuery',hot:false},
        {label:'Thymeleaf',hot:false},
        {label:'Astro',hot:false},
        {label:'Tailwind CSS',hot:false},
        {label:'Node.js',hot:false},
        {label:'PHP',hot:false},
        {label:'Git',hot:false},
        {label:'Netlify',hot:false},
        {label:'Nginx',hot:false},
      ].map(skill => (
        <span class="px-4 py-2 rounded-full text-sm border" style={skill.hot ? 'background:rgba(0,212,170,0.08);border-color:rgba(0,212,170,0.3);color:#00d4aa;' : 'background:#131720;border-color:rgba(255,255,255,0.08);color:#8b909e;'}>
          {skill.label}
        </span>
      ))}
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-24 px-8 max-w-6xl mx-auto border-t border-white/5">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">Get in touch</div>
    <h2 class="text-3xl font-bold text-white mb-4">Let's build something together</h2>
    <p class="text-[#8b909e] mb-10 max-w-lg">Have a business problem that AI could solve? Not sure where to start? Let's have a conversation — no jargon, no pressure.</p>

    <a href="mailto:hello@carloschluter.com" class="inline-flex items-center gap-3 px-8 py-4 rounded-lg font-semibold transition-opacity hover:opacity-90" style="background:#00d4aa;color:#0d0f14;">
      <i class="ti ti-mail"></i>
      hello@carloschluter.com
    </a>
  </section>

  <!-- FOOTER -->
  <footer class="py-8 px-8 border-t border-white/5">
    <div class="max-w-6xl mx-auto flex flex-wrap justify-between items-center gap-4">
      <div class="text-sm text-[#555a6b]">© 2026 Carlo Schluter · carloschluter.com</div>
      <div class="flex items-center gap-2 text-sm text-[#555a6b]">
        <span class="w-2 h-2 rounded-full" style="background:#00d4aa;"></span>
        Built with AI · Powered by Astro
      </div>
    </div>
  </footer>

  <script>
    window.addEventListener('load', () => {
      const photo = document.getElementById('carlo-photo');
      const overlay = document.getElementById('teal-overlay');
      const outer = document.getElementById('photo-outer');

      if (outer && photo) {
        outer.addEventListener('mouseenter', () => {
          photo.style.filter = 'saturate(1) brightness(1) sepia(0) hue-rotate(0deg) contrast(1)';
          if (overlay) overlay.style.opacity = '0';
        });
        outer.addEventListener('mouseleave', () => {
          photo.style.filter = 'saturate(0.15) brightness(0.9) sepia(0.4) hue-rotate(130deg) contrast(1.1)';
          if (overlay) overlay.style.opacity = '1';
        });
      }
    });
  </script>

</Layout>