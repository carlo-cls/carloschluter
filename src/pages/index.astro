              <i class="ti ti-mail" style="color:#00d4aa;font-size:18px;"></i>
            </div>
            hello@carloschluter.com
          </a>
          <a href="https://linkedin.com/in/carloschluter" target="_blank" class="inline-flex items-center gap-3 text-sm text-[#8b909e] hover:text-white transition-colors">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(91,141,238,0.1);">
              <i class="ti ti-brand-linkedin" style="color:#5b8dee;font-size:18px;"></i>
