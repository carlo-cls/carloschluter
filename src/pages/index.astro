  <script>
    window.addEventListener('load', () => {
      const photo = document.getElementById('carlo-photo');
      const overlay = document.getElementById('teal-overlay');
      const outer = document.getElementById('photo-outer');

      if (outer && photo) {
        outer.addEventListener('mouseenter', () => {
          photo.style.filter = 'saturate(1) brightness(1) sepia(0) hue-rotate(0deg) contrast(1)';
          if (overlay) overlay.style.opacity = '0';
        });
        outer.addEventListener('mouseleave', () => {
          photo.style.filter = 'saturate(0.15) brightness(0.9) sepia(0.4) hue-rotate(130deg) contrast(1.1)';
          if (overlay) overlay.style.opacity = '1';
        });
      }
    });
  </script>

  <script>
    window.addEventListener('load', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const success = document.getElementById('form-success');

      console.log('Form found:', form);
      console.log('Success div found:', success);

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          console.log('Form submitted');
          
          const data = new FormData(form);
          const encoded = Array.from(data.entries())
            .map(([key, val]) => encodeURIComponent(key) + '=' + encodeURIComponent(val.toString()))
            .join('&');

          try {
            const response = await fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: encoded
            });
            console.log('Fetch response status:', response.status);
            form.style.display = 'none';
            console.log('Form hidden');
            if (success) {
              success.style.display = 'block';
              console.log('Success shown');
            } else {
              console.log('Success div not found!');
            }
          } catch (err) {
            console.log('Error:', err);
          }
        });
      }
    });
  </script>

  <script>
    window.addEventListener('load', () => {
      const tabs = document.querySelectorAll('.skill-tab');
      const cards = document.querySelectorAll('.skill-card');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          const cat = (tab as HTMLElement).dataset.cat;
          cards.forEach(card => {
            const c = card as HTMLElement;
            if (cat === 'all' || c.dataset.cat === cat) {
              c.classList.remove('hidden');
            } else {
              c.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>


