      {name:'Spring Boot',cat:'backend',catLabel:'Backend',icon:'ti-leaf',color:'#5b8dee',bg:'rgba(91,141,238,0.08)',border:'rgba(91,141,238,0.3)',desc:'REST APIs, Spring Security, JPA/Hibernate, dependency injection and microservice architecture'},
      {name:'MySQL',cat:'backend',catLabel:'Backend',icon:'ti-database',color:'#5b8dee',bg:'rgba(91,141,238,0.08)',border:'rgba(91,141,238,0.3)',desc:'Complex stored procedures, views, query optimisation, schema design and performance tuning'},
      {name:'Node.js',cat:'backend',catLabel:'Backend',icon:'ti-brand-nodejs',color:'#5b8dee',bg:'rgba(91,141,238,0.08)',border:'rgba(91,141,238,0.3)',desc:'REST APIs, serverless functions, real-time backend services and Express middleware'},
      {name:'PHP',cat:'backend',catLabel:'Backend',icon:'ti-brand-php',color:'#5b8dee',bg:'rgba(91,141,238,0.08)',border:'rgba(91,141,238,0.3)',desc:'Custom web applications, WordPress development and MySQL integration'},
      {name:'JavaScript',cat:'frontend',catLabel:'Frontend',icon:'ti-brand-javascript',color:'#EF9F27',bg:'rgba(239,159,39,0.08)',border:'rgba(239,159,39,0.3)',desc:'ES6+, async/await, DOM manipulation, AJAX and interactive UI development across multiple frameworks'},
      {name:'Bootstrap',cat:'frontend',catLabel:'Frontend',icon:'ti-brand-bootstrap',color:'#EF9F27',bg:'rgba(239,159,39,0.08)',border:'rgba(239,159,39,0.3)',desc:'Responsive layouts, component systems and enterprise UI development'},
      {name:'Tailwind CSS',cat:'frontend',catLabel:'Frontend',icon:'ti-brand-tailwind',color:'#EF9F27',bg:'rgba(239,159,39,0.08)',border:'rgba(239,159,39,0.3)',desc:'Utility-first styling, custom design systems and responsive components'},
      {name:'jQuery',cat:'frontend',catLabel:'Frontend',icon:'ti-code',color:'#EF9F27',bg:'rgba(239,159,39,0.08)',border:'rgba(239,159,39,0.3)',desc:'DOM manipulation, AJAX, DataTables, jsTree and interactive UI components'},
      {name:'Astro',cat:'frontend',catLabel:'Frontend',icon:'ti-rocket',color:'#EF9F27',bg:'rgba(239,159,39,0.08)',border:'rgba(239,159,39,0.3)',desc:'Static site generation, component islands and modern web performance optimisation'},
      {name:'Git',cat:'tools',catLabel:'Tools',icon:'ti-brand-git',color:'#a0a8b0',bg:'rgba(255,255,255,0.05)',border:'rgba(255,255,255,0.12)',desc:'Branching strategies, pull requests, Bitbucket and GitHub workflows'},
      {name:'VS Code',cat:'tools',catLabel:'Tools',icon:'ti-brand-vscode',color:'#a0a8b0',bg:'rgba(255,255,255,0.05)',border:'rgba(255,255,255,0.12)',desc:'Primary IDE with extensions for AI-assisted development'},
      {name:'Netlify',cat:'tools',catLabel:'Tools',icon:'ti-world',color:'#a0a8b0',bg:'rgba(255,255,255,0.05)',border:'rgba(255,255,255,0.12)',desc:'CI/CD deployment, serverless functions and edge hosting'},
      {name:'Nginx',cat:'tools',catLabel:'Tools',icon:'ti-server',color:'#a0a8b0',bg:'rgba(255,255,255,0.05)',border:'rgba(255,255,255,0.12)',desc:'VPS configuration, reverse proxy, SSL and production server management'},
      {name:'Bitbucket',cat:'tools',catLabel:'Tools',icon:'ti-git-branch',color:'#a0a8b0',bg:'rgba(255,255,255,0.05)',border:'rgba(255,255,255,0.12)',desc:'Git repository management, pull requests and team code collaboration'},
      {name:'JasperReports',cat:'tools',catLabel:'Tools',icon:'ti-file-report',color:'#a0a8b0',bg:'rgba(255,255,255,0.05)',border:'rgba(255,255,255,0.12)',desc:'Enterprise reporting, PDF generation and complex data visualisation'},
    ];

    let currentCat = 'all';
    let selected: string | null = null;

    const pillsWrap = document.getElementById('skills-pills');
    const detail = document.getElementById('skills-detail');
    const empty = document.getElementById('skills-empty');
    const content = document.getElementById('skills-content');
    const iconEl = document.getElementById('skills-icon');
    const nameEl = document.getElementById('skills-name');
    const catEl = document.getElementById('skills-cat');
    const descEl = document.getElementById('skills-desc');

    function renderPills() {
      if (!pillsWrap) return;
      pillsWrap.innerHTML = '';
      const filtered = currentCat === 'all' ? skills : skills.filter(s => s.cat === currentCat);
      filtered.forEach(skill => {
        const pill = document.createElement('button');
        const isSelected = selected === skill.name;
        pill.setAttribute('style', `
          font-size:13px;
          padding:6px 14px;
          border-radius:8px;
          border:1px solid ${skill.border};
          background:${skill.bg};
          color:${skill.color};
          cursor:pointer;
          display:inline-flex;
          align-items:center;
          gap:6px;
          font-family:'Space Grotesk',sans-serif;
          transition:all 0.15s;
          ${isSelected ? `box-shadow:0 0 0 2px ${skill.color};` : ''}
        `);
        pill.innerHTML = `<i class="ti ${skill.icon}" aria-hidden="true"></i><span>${skill.name}</span>`;
        pill.addEventListener('click', () => selectSkill(skill));
        pillsWrap.appendChild(pill);
      });
    }

    function selectSkill(skill: any) {
      selected = skill.name;
      renderPills();
      if (!detail || !empty || !content || !iconEl || !nameEl || !catEl || !descEl) return;
      detail.style.borderColor = skill.border;
      empty.style.display = 'none';
      content.style.display = 'block';
      iconEl.style.background = skill.bg;
      iconEl.innerHTML = `<i class="ti ${skill.icon}" style="color:${skill.color};font-size:18px" aria-hidden="true"></i>`;
      nameEl.textContent = skill.name;
      nameEl.style.color = skill.color;
      catEl.textContent = skill.catLabel;
      catEl.style.color = skill.color;
      descEl.textContent = skill.desc;
    }

    document.querySelectorAll('.skill-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.skill-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentCat = (tab as HTMLElement).dataset.cat || 'all';
        selected = null;
        if (detail) detail.style.borderColor = 'rgba(255,255,255,0.07)';
        if (empty) empty.style.display = 'block';
        if (content) content.style.display = 'none';
        renderPills();
      });
    });

    renderPills();
  });
  </script>

  <script>
    window.addEventListener('load', () => {
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const lines = document.querySelectorAll('.hamburger-line') as NodeListOf<HTMLElement>;
      let open = false;

      btn?.addEventListener('click', () => {
        open = !open;
        if (menu) menu.style.display = open ? 'block' : 'none';

        // Animate hamburger to X
        if (open) {
          lines[0].style.transform = 'translateY(7px) rotate(45deg)';
          lines[1].style.opacity = '0';
          lines[2].style.transform = 'translateY(-7px) rotate(-45deg)';
        } else {
          lines[0].style.transform = 'none';
          lines[1].style.opacity = '1';
          lines[2].style.transform = 'none';
        }
      });

      // Close menu when a link is clicked
      document.querySelectorAll('.mobile-nav-link').forEach(link => {
        link.addEventListener('click', () => {
          open = false;
          if (menu) menu.style.display = 'none';
          lines[0].style.transform = 'none';
          lines[1].style.opacity = '1';
          lines[2].style.transform = 'none';
        });
      });
    });
  </script>  

  <script>
    window.addEventListener('load', () => {
      document.querySelectorAll('.ind-header').forEach(header => {
        header.addEventListener('click', () => {
          const item = header.closest('.ind-item') as HTMLElement;
          const isOpen = item.dataset.open === 'true';

          // Close all items first
          document.querySelectorAll('.ind-item').forEach(i => {
            (i as HTMLElement).dataset.open = 'false';
          });

          // If it wasn't open, open it
          if (!isOpen) {
            item.dataset.open = 'true';
          }
        });
      });
    });
  </script>

