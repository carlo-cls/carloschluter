  <style>
    .skill-tab {
      padding: 6px 16px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.1);
      background: transparent;
      color: #8b909e;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.15s;
      font-family: 'Space Grotesk', sans-serif;
    }
    .skill-tab:hover {
      border-color: rgba(255,255,255,0.2);
      color: #fff;
    }
    .skill-tab.active {
      background: rgba(0,212,170,0.1);
      border-color: rgba(0,212,170,0.35);
      color: #00d4aa;
    }
    .skill-card {
      height: 100px;
      perspective: 800px;
      cursor: pointer;
    }
    .flip-inner {
      width: 100%;
      height: 100%;
      position: relative;
      transform-style: preserve-3d;
      transition: transform 0.45s ease;
    }
    .skill-card:hover .flip-inner {
      transform: rotateY(180deg);
    }
    .flip-front, .flip-back {
      position: absolute;
      inset: 0;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      backface-visibility: hidden;
      padding: 12px;
      text-align: center;
      font-size: 13px;
      font-weight: 500;
    }
    .flip-front {
      background: #131720;
      border: 1px solid rgba(255,255,255,0.07);
      color: #e8eaf0;
    }
    .flip-back {
      background: #0d0f14;
      border: 1px solid;
      color: #00d4aa;
      transform: rotateY(180deg);
      font-size: 11px;
      font-weight: 400;
      line-height: 1.5;
    }
    .skill-card.hidden {
      display: none;
    }
  </style>

