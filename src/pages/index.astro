---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- NAVIGATION -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5" style="background:#0d0f14;">
    <div class="flex items-center justify-between px-8 py-4">
      <div class="text-white font-bold text-lg tracking-tight">
        carlo<span style="color:#00d4aa">.</span>schluter
      </div>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="text-sm text-[#8b909e] hover:text-white transition-colors">About</a>
        <a href="#services" class="text-sm text-[#8b909e] hover:text-white transition-colors">Services</a>
        <a href="#process" class="text-sm text-[#8b909e] hover:text-white transition-colors">Process</a>
        <a href="#skills" class="text-sm text-[#8b909e] hover:text-white transition-colors">Skills</a>
        <a href="#roadmap" class="text-sm text-[#8b909e] hover:text-white transition-colors">Roadmap</a>
        <a href="#contact" class="text-sm text-[#8b909e] hover:text-white transition-colors">Contact</a>
      </div>
      <a href="#contact" class="hidden md:inline-flex text-sm font-semibold px-4 py-2 rounded-lg transition-colors" style="background:#00d4aa;color:#0d0f14;">
        Let's talk
      </a>

      <!-- Mobile hamburger button -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5" aria-label="Toggle menu">
        <span class="hamburger-line" style="display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all 0.3s;"></span>
        <span class="hamburger-line" style="display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all 0.3s;"></span>
        <span class="hamburger-line" style="display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all 0.3s;"></span>
      </button>
    </div>

    <!-- Mobile menu dropdown -->
    <div id="mobile-menu" style="display:none;border-top:1px solid rgba(255,255,255,0.05);">
      <div class="flex flex-col px-8 py-6 gap-1">
        <a href="#about" class="mobile-nav-link text-sm text-[#8b909e] hover:text-white transition-colors py-3 border-b border-white/5">About</a>
        <a href="#services" class="mobile-nav-link text-sm text-[#8b909e] hover:text-white transition-colors py-3 border-b border-white/5">Services</a>
        <a href="#process" class="mobile-nav-link text-sm text-[#8b909e] hover:text-white transition-colors py-3 border-b border-white/5">Process</a>
        <a href="#skills" class="mobile-nav-link text-sm text-[#8b909e] hover:text-white transition-colors py-3 border-b border-white/5">Skills</a>
        <a href="#roadmap" class="mobile-nav-link text-sm text-[#8b909e] hover:text-white transition-colors py-3 border-b border-white/5">Roadmap</a>
        <a href="#contact" class="mobile-nav-link text-sm text-[#8b909e] hover:text-white transition-colors py-3">Contact</a>
        <div class="pt-4">
          <a href="#contact" class="mobile-nav-link text-sm font-semibold px-6 py-3 rounded-lg transition-colors inline-block" style="background:#00d4aa;color:#0d0f14;">
            Let's talk
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-8 pt-24 pb-16 max-w-6xl mx-auto">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium mb-8 w-fit" style="background:rgba(0,212,170,0.1);border:1px solid rgba(0,212,170,0.25);color:#00d4aa;">
      <span class="w-2 h-2 rounded-full" style="background:#00d4aa;"></span>
      Available for AI projects · Gauteng, South Africa
    </div>

    <h1 class="text-5xl md:text-7xl font-bold leading-tight tracking-tight mb-6">
      Carlo Schluter<br />
      <span style="background:linear-gradient(135deg,#00d4aa,#5b8dee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
        AI Solutions Engineer
      </span>
    </h1>

    <p class="text-lg text-[#8b909e] max-w-xl leading-relaxed mb-10">
      I help <strong class="text-[#c8cad4] font-medium">South African businesses</strong> implement AI in ways that are practical, meaningful, and built to last — without the jargon, without the overwhelm.
    </p>

    <div class="flex flex-wrap gap-4 mb-16">
      <a href="#services" class="px-6 py-3 rounded-lg font-semibold text-sm transition-opacity hover:opacity-90" style="background:#00d4aa;color:#0d0f14;">
        See what I build
      </a>
      <a href="#contact" class="px-6 py-3 rounded-lg font-semibold text-sm border transition-colors hover:border-white/30" style="border-color:rgba(255,255,255,0.12);color:#e8eaf0;">
        Get in touch
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-px mt-12 rounded-xl overflow-hidden border border-white/5">

      <div class="flex flex-col items-center justify-center py-6 px-4 text-center" style="background:#131720;">
        <div class="text-3xl font-bold text-white mb-1">25+</div>
        <div class="text-xs text-[#8b909e] uppercase tracking-widest">Years engineering</div>
      </div>

      <div class="flex flex-col items-center justify-center py-6 px-4 text-center" style="background:#131720;">
        <div class="text-3xl font-bold mb-1" style="color:#00d4aa;">3</div>
        <div class="text-xs text-[#8b909e] uppercase tracking-widest">AI specialisations</div>
      </div>

      <div class="flex flex-col items-center justify-center py-6 px-4 text-center" style="background:#131720;">
        <div class="text-3xl font-bold mb-1" style="color:#5b8dee;">10+</div>
        <div class="text-xs text-[#8b909e] uppercase tracking-widest">Industries served</div>
      </div>

      <div class="flex flex-col items-center justify-center py-6 px-4 text-center" style="background:#131720;">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 rounded-full" style="background:#00d4aa;animation:pulse 2s infinite;"></span>
          <div class="text-3xl font-bold" style="color:#EF9F27;">Open</div>
        </div>
        <div class="text-xs text-[#8b909e] uppercase tracking-widest">For projects</div>
      </div>

    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-24 px-8 max-w-6xl mx-auto border-t border-white/5">
    <div class="flex flex-col md:flex-row items-center gap-16">

      <!-- Photo -->
      <div id="photo-outer" class="relative flex-shrink-0 flex items-center justify-center" style="width:220px;height:254px;">

        <!-- Outer rotating ring -->
        <div style="
          position:absolute;
          inset:-4px;
          border-radius:4px;
          background:conic-gradient(from 0deg,#00d4aa,#5b8dee,#00d4aa);
          clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
          animation:rotatering 6s linear infinite;
          opacity:0.85;
        "></div>

        <!-- Dark inset behind photo -->
        <div style="
          position:absolute;
          inset:3px;
          background:#0d0f14;
          clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
        "></div>

        <!-- Photo with teal tint effect -->
        <div class="photo-hex-wrap" style="
          position:absolute;
          inset:5px;
          clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
          overflow:hidden;
        ">
        <img
          id="carlo-photo"
          src="/images/carlo.jpg"
          alt="Carlo Schluter"
          style="
            width:100%;
            height:100%;
            object-fit:cover;
            object-position:top;
            filter:saturate(0.15) brightness(0.9) sepia(0.4) hue-rotate(130deg) contrast(1.1);
            transition:filter 0.5s ease;
          "
        />
        <div
          id="teal-overlay"
          style="
            position:absolute;
            inset:0;
            background:rgba(0,212,170,0.12);
            mix-blend-mode:screen;
            transition:opacity 0.5s ease;
          "
        ></div> 
        </div>

        <!-- Dashed outer hex ring -->
        <svg style="position:absolute;inset:-12px;width:calc(100% + 24px);height:calc(100% + 24px);overflow:visible;" viewBox="0 0 244 278">
          <polygon
            points="122,6 238,68 238,210 122,272 6,210 6,68"
            fill="none"
            stroke="#5b8dee"
            stroke-width="1"
            stroke-dasharray="6 5"
            opacity="0.4"
          />
        </svg>

        <!-- Available badge -->
        <div style="
          position:absolute;
          bottom:-18px;
          left:50%;
          transform:translateX(-50%);
          display:flex;
          align-items:center;
          gap:6px;
          padding:5px 14px;
          border-radius:20px;
          font-size:11px;
          font-weight:600;
          white-space:nowrap;
          background:#0d0f14;
          border:1px solid rgba(0,212,170,0.4);
          color:#00d4aa;
        ">
          <span style="width:6px;height:6px;border-radius:50%;background:#00d4aa;animation:pulse 2s infinite;"></span>
          Available for projects
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1">
        <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">About me</div>
        <h2 class="text-3xl font-bold text-white mb-6">Bridging AI capability<br/>and business reality</h2>
        <p class="text-[#8b909e] leading-relaxed mb-4">
          I'm a Development Team Lead and AI Solutions Engineer based in Gauteng, South Africa, with over 25 years of experience building production software systems — from enterprise web platforms and real-time data pipelines to CRM integrations and mobile applications.
        </p>
        <p class="text-[#8b909e] leading-relaxed mb-4">
          What drives me is the translation work — taking something technically complex and turning it into something that genuinely works for a business and its people. I remove unnecessary complexity, communicate clearly without jargon, and build solutions that hold up long after I've handed them over.
        </p>
        <p class="text-[#8b909e] leading-relaxed mb-8">
          Now I'm applying that same approach to AI — helping established South African businesses implement intelligent systems that save time, surface insights, and create real competitive advantage.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://linkedin.com/in/carloschluter" target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-colors hover:border-[#00d4aa]/50" style="border-color:rgba(255,255,255,0.12);color:#e8eaf0;">
            <i class="ti ti-brand-linkedin" style="color:#0077b5;"></i>
            LinkedIn
          </a>
          <a href="https://github.com/carlo-cls" target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border transition-colors hover:border-[#00d4aa]/50" style="border-color:rgba(255,255,255,0.12);color:#e8eaf0;">
            <i class="ti ti-brand-github"></i>
            GitHub
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="py-24 px-8 max-w-6xl mx-auto border-t border-white/5">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">Experience across industries</div>
    <h2 class="text-3xl font-bold text-white mb-4">Industries I've worked in</h2>
    <p class="text-[#8b909e] mb-12 max-w-xl">Over 25 years I've built production systems across a wide range of South African and international industries. Click any to learn more.</p>

    <div class="grid md:grid-cols-2 gap-3" id="industries-grid">

      <div class="ind-item" data-open="true">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(0,212,170,0.1);">
              <i class="ti ti-building-arch" style="color:#00d4aa;font-size:16px;"></i>
            </div>
            <div>
              <div class="ind-name">Civil Engineering</div>
              <span class="ind-badge">Current</span>
            </div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Enterprise project management platform for large-scale infrastructure</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(91,141,238,0.1);">
              <i class="ti ti-plant" style="color:#5b8dee;font-size:16px;"></i>
            </div>
            <div class="ind-name">Agriculture</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Real-time commodity pricing & mobile data platform for smallholder farmers across SA</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(239,159,39,0.1);">
              <i class="ti ti-home" style="color:#EF9F27;font-size:16px;"></i>
            </div>
            <div class="ind-name">Real Estate</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">CRM modules & campaign automation for real estate agents across South Africa</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(0,212,170,0.1);">
              <i class="ti ti-car" style="color:#00d4aa;font-size:16px;"></i>
            </div>
            <div class="ind-name">Automotive</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Motor body repair financial system for Anglo African Finance</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(91,141,238,0.1);">
              <i class="ti ti-report-money" style="color:#5b8dee;font-size:16px;"></i>
            </div>
            <div class="ind-name">Financial Services</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Insurance policy systems & daily banking batch imports for major institutions</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(239,159,39,0.1);">
              <i class="ti ti-music" style="color:#EF9F27;font-size:16px;"></i>
            </div>
            <div class="ind-name">Music & Entertainment</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Full e-commerce platform for digital audio track sales — 25% revenue increase</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(0,212,170,0.1);">
              <i class="ti ti-heart-rate-monitor" style="color:#00d4aa;font-size:16px;"></i>
            </div>
            <div class="ind-name">Healthcare</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Medical aid claims processing & broker management systems</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(91,141,238,0.1);">
              <i class="ti ti-device-mobile" style="color:#5b8dee;font-size:16px;"></i>
            </div>
            <div class="ind-name">Telecommunications</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Facility management & biometric security systems for MTN</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(239,159,39,0.1);">
              <i class="ti ti-school" style="color:#EF9F27;font-size:16px;"></i>
            </div>
            <div class="ind-name">Education</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Student portals & university procurement reporting systems</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(0,212,170,0.1);">
              <i class="ti ti-shopping-cart" style="color:#00d4aa;font-size:16px;"></i>
            </div>
            <div class="ind-name">E-commerce & Retail</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Payment gateway integrations & custom online store platforms</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(91,141,238,0.1);">
              <i class="ti ti-scale" style="color:#5b8dee;font-size:16px;"></i>
            </div>
            <div class="ind-name">Legal & Debt</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Debt counselling web applications & document management systems</p>
        </div>
      </div>

      <div class="ind-item">
        <div class="ind-header">
          <div class="ind-left">
            <div class="ind-icon" style="background:rgba(239,159,39,0.1);">
              <i class="ti ti-trophy" style="color:#EF9F27;font-size:16px;"></i>
            </div>
            <div class="ind-name">Sports & Events</div>
          </div>
          <i class="ti ti-chevron-down ind-chevron"></i>
        </div>
        <div class="ind-body">
          <p class="ind-desc">Sensor testing & systems work for 2010 FIFA World Cup venues</p>
        </div>
      </div>

    </div>
  </section>  

  <style>
    @keyframes rotatering {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    .photo-hex-wrap:hover .photo-hex {
      filter: saturate(1) brightness(1) sepia(0) hue-rotate(0deg) contrast(1) !important;
    }
    .photo-hex-wrap:hover .teal-overlay {
      opacity: 0 !important;
    }
    html {
      scroll-behavior: smooth;
    }
    .industry-card {
      transition: border-color 0.2s, transform 0.2s;
    }
    .industry-card:hover {
      border-color: rgba(0,212,170,0.25) !important;
      transform: translateY(-2px);
    }
    .ind-item {
      background: #131720;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .ind-item[data-open="true"] {
      border-color: rgba(0,212,170,0.35);
    }
    .ind-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px;
      cursor: pointer;
      gap: 10px;
      user-select: none;
    }
    .ind-header:hover {
      background: rgba(255,255,255,0.02);
    }
    .ind-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .ind-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .ind-name {
      font-size: 13px;
      font-weight: 600;
      color: #e8eaf0;
    }
    .ind-badge {
      font-size: 9px;
      font-weight: 600;
      padding: 2px 7px;
      border-radius: 10px;
      background: rgba(0,212,170,0.1);
      color: #00d4aa;
      border: 1px solid rgba(0,212,170,0.2);
      display: inline-block;
      margin-top: 3px;
    }
    .ind-chevron {
      font-size: 14px;
      color: #555a6b;
      transition: transform 0.25s;
      flex-shrink: 0;
    }
    .ind-item[data-open="true"] .ind-chevron {
      transform: rotate(180deg);
    }
    .ind-body {
      display: none;
      padding: 0 14px 12px 56px;
    }
    .ind-item[data-open="true"] .ind-body {
      display: block;
    }
    .ind-desc {
      font-size: 12px;
      color: #8b909e;
      line-height: 1.6;
    }    
    .svc-flip {
      height: 320px;
      perspective: 1000px;
      cursor: pointer;
    }
    .svc-inner {
      width: 100%;
      height: 100%;
      position: relative;
      transform-style: preserve-3d;
      transition: transform 0.5s ease;
    }
    .svc-flip:hover .svc-inner {
      transform: rotateY(180deg);
    }
    .svc-front, .svc-back {
      position: absolute;
      inset: 0;
      border-radius: 16px;
      padding: 28px;
      backface-visibility: hidden;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }
    .svc-front {
      background: #131720;
      border: 1px solid rgba(255,255,255,0.07);
    }
    .svc-back {
      background: #0d0f14;
      border: 1px solid;
      transform: rotateY(180deg);
    }    
  </style>  

  <!-- SERVICES -->
  <section id="services" class="py-24 px-8 max-w-6xl mx-auto">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color:#00d4aa;">What I build</div>
    <h2 class="text-3xl font-bold text-white mb-4">AI solutions for real business problems</h2>
    <p class="text-[#8b909e] mb-12 max-w-xl">Hover or tap any service to see what's included and who it's for.</p>

    <div class="grid md:grid-cols-3 gap-6">

      <div class="svc-flip">
        <div class="svc-inner">
          <div class="svc-front">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(0,212,170,0.1);">
              <i class="ti ti-brain" style="color:#00d4aa;font-size:24px;"></i>
            </div>
            <h3 class="text-lg font-semibold text-white mb-3">AI Web Solutions</h3>
            <p class="text-sm text-[#8b909e] leading-relaxed">Intelligent apps, chatbots, smart search, and automation built directly into your web presence.</p>
            <div class="mt-6 text-xs font-medium" style="color:#00d4aa;">Hover to see what's included →</div>
          </div>
